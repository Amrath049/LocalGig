// LocalGig data model — hyperlocal job board (single-city MVP).
// See docs / project plan for the product context.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ----------------------------------------------------------------
// Enums
// ----------------------------------------------------------------

enum Role {
  WORKER
  EMPLOYER
}

enum JobType {
  FULL_TIME
  PART_TIME
  GIG
}

// Pay is optional on a Job. When provided, payType describes its shape:
//   FIXED  -> payAmount
//   RANGE  -> payMin + payMax
//   CUSTOM -> payCustom (free-text message)
enum PayType {
  FIXED
  RANGE
  CUSTOM
}

enum JobStatus {
  OPEN
  CLOSED
}

enum ApplicationStatus {
  APPLIED
  SEEN
  SHORTLISTED
  HIRED
  NOT_SELECTED
}

// ----------------------------------------------------------------
// Models
// ----------------------------------------------------------------

model User {
  id              String   @id @default(uuid())
  email           String   @unique
  passwordHash    String
  role            Role
  isEmailVerified Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Role-specific profiles (one-to-one, exactly one is populated per role)
  workerProfile   WorkerProfile?
  employerProfile EmployerProfile?

  // Employer: jobs they posted
  postedJobs      Job[]

  // Worker: applications they submitted
  applications    Application[]

  // Active refresh tokens (rotation store)
  refreshTokens   RefreshToken[]

  @@index([role])
}

model WorkerProfile {
  id        String   @id @default(uuid())
  userId    String   @unique
  name      String
  phone     String
  skillTags String[] // e.g. ["plumbing", "electrical"]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model EmployerProfile {
  id           String   @id @default(uuid())
  userId       String   @unique
  businessName String
  phone        String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Job {
  id          String    @id @default(uuid())
  title       String
  description String
  type        JobType
  location    String? // area / locality within the city
  status      JobStatus @default(OPEN)

  // Optional pay (see PayType enum)
  payType   PayType?
  payAmount Int? // when FIXED
  payMin    Int? // when RANGE
  payMax    Int? // when RANGE
  payCustom String? // when CUSTOM

  // Owner (employer)
  employerId String
  employer   User   @relation(fields: [employerId], references: [id], onDelete: Cascade)

  applications Application[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  closedAt  DateTime? // set when an employer manually closes the job

  @@index([employerId])
  @@index([status])
  @@index([type])
}

model Application {
  id       String            @id @default(uuid())
  status   ApplicationStatus @default(APPLIED)
  message  String? // optional note from the worker

  jobId    String
  job      Job  @relation(fields: [jobId], references: [id], onDelete: Cascade)

  workerId String
  worker   User @relation(fields: [workerId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // A worker can apply to a given job only once
  @@unique([jobId, workerId])
  @@index([jobId])
  @@index([workerId])
  @@index([status])
}

// Persisted refresh tokens for rotation. We store only a SHA-256 hash of the
// token, never the raw value. On refresh the old row is deleted and a new one
// created (rotation); on logout the row(s) are revoked.
model RefreshToken {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
}
