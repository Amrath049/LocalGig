# ============================================================
# LocalGig backend — env template. Copy to `.env` and fill in.
#   cp .env.example .env
# ============================================================

# --- App ---
NODE_ENV=development
PORT=4000
FRONTEND_URL=http://localhost:3000

# --- Database (Postgres via docker-compose) ---
DATABASE_URL="postgresql://localgig:localgig@localhost:5432/localgig?schema=public"

# --- Redis (via docker-compose) ---
REDIS_HOST=localhost
REDIS_PORT=6379

# --- Elasticsearch (via docker-compose) ---
# Example when using the internal OpenSearch user `localgig_backend` with the
# provided password. The password contains special characters and must be URL-encoded
# when included in a URL. Encoded password for `ES_Password#2026!Q7mX9Lp@K2v` is:
# ES_Password%232026%21Q7mX9Lp%40K2v
ELASTICSEARCH_NODE="https://localgig_backend:ES_Password%232026%21Q7mX9Lp%40K2v@opensearch.example.com:9200"

# --- Auth / JWT (used from Phase 2) ---
JWT_ACCESS_SECRET=replace_with_a_long_random_string
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=replace_with_a_different_long_random_string
JWT_REFRESH_EXPIRES_IN=7d

# --- Mail / SendGrid (used from Phase 2) ---
SENDGRID_API_KEY=
MAIL_FROM=no-reply@localgig.local
