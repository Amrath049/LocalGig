{
  "permissions": {
    "allow": [
      "Bash(node -e \"const p=require\\('./node_modules/@prisma/config/package.json'\\); console.log\\('version',p.version\\); console.log\\('main',p.main\\); console.log\\('types',p.types||p.typings\\); console.log\\('exports',JSON.stringify\\(p.exports,null,1\\)\\)\")",
      "Bash(node -e \"console.log\\('prisma CLI :', require\\('prisma/package.json'\\).version\\)\")",
      "Bash(node -e \"console.log\\('@prisma/client:', require\\('@prisma/client/package.json'\\).version\\)\")",
      "Bash(node -e \"console.log\\('@prisma/config:', require\\('@prisma/config/package.json'\\).version\\)\")",
      "Bash(npx prisma *)",
      "PowerShell(Get-CimInstance Win32_Process -Filter \"Name='node.exe'\" | Select-Object ProcessId, @{n='Cmd';e={$_.CommandLine}} | Where-Object { $_.Cmd -match 'nest|backend' } | Format-Table -AutoSize -Wrap)"
    ]
  }
}
